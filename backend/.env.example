# Ruta de la base de datos de rostros
# En contenedores Docker, esto suele ser /app/db/faces
DB_PATH=./db/faces

# Orígenes CORS permitidos (separados por coma)
# Ejemplo: https://misistema.midominio.com,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Desactiva el uso de ventanas nativas "tkinter" para explorar carpetas
# (Requerido en producción headless o Docker)
DISABLE_NATIVE_FILE_PICKER=true
